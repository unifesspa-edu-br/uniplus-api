<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Serilog.AspNetCore" />
    <PackageReference Include="WolverineFx.Postgresql" />
  </ItemGroup>

  <!--
    Composition root do monólito modular. Referencia os 5 módulos internos
    (Selecao, Ingresso, Configuracao, OrganizacaoInstitucional) e os compõe num
    processo único. Geo e Portal permanecem deploys separados. Este assembly é o
    único autorizado a depender de múltiplos módulos — fica FORA do ModulesRoster
    do fitness R8 (CrossModuleReadIsolationTests).
  -->
  <ItemGroup>
    <ProjectReference Include="..\..\selecao\Unifesspa.UniPlus.Selecao.API\Unifesspa.UniPlus.Selecao.API.csproj" />
    <ProjectReference Include="..\..\ingresso\Unifesspa.UniPlus.Ingresso.API\Unifesspa.UniPlus.Ingresso.API.csproj" />
    <ProjectReference Include="..\..\publicacoes\Unifesspa.UniPlus.Publicacoes.API\Unifesspa.UniPlus.Publicacoes.API.csproj" />
    <ProjectReference Include="..\..\configuracao\Unifesspa.UniPlus.Configuracao.API\Unifesspa.UniPlus.Configuracao.API.csproj" />
    <ProjectReference Include="..\..\organizacao-institucional\Unifesspa.UniPlus.OrganizacaoInstitucional.API\Unifesspa.UniPlus.OrganizacaoInstitucional.API.csproj" />
  </ItemGroup>

  <!--
    Co-hosting limpo: os 4 .API referenciados são class libraries (Sdk padrão, não
    Sdk.Web) e NÃO carregam appsettings*.json próprios. Só este host emite
    appsettings para o publish, então não há colisão NETSDK1152 — o target de
    remoção que existia aqui virou desnecessário e foi removido (a conversão dos
    módulos em libraries é a correção de raiz).
  -->

</Project>
