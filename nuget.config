<?xml version="1.0" encoding="utf-8"?>
<!--
  Feed local temporário para incorporar o fix do upstream JasperFx/wolverine#2586
  (DomainEventScraper materializa eventos antes de publicar) sem aguardar release
  oficial do Wolverine 5.32.2+. Ver chore/wolverine-pr2586-local-feed e ADR-024.

  Quando o upstream publicar a versão com o fix:
    1. Bumpar versão em Directory.Packages.props para a versão oficial.
    2. Remover este arquivo (ou apagar o feed `wolverine-pr2586`).
    3. Apagar pasta vendors/nuget-local/.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="wolverine-pr2586" value="./vendors/nuget-local" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="wolverine-pr2586">
      <package pattern="WolverineFx" />
      <package pattern="WolverineFx.EntityFrameworkCore" />
      <package pattern="WolverineFx.RDBMS" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
